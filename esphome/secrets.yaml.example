# esphome/secrets.yaml.example
# Copy this file to esphome/secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit it.
#
# cp esphome/secrets.yaml.example esphome/secrets.yaml

wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"

# Generate with: esphome generate-key
api_encryption_key: ""

# Fallback WiFi AP (shown when main WiFi is unreachable)
ap_ssid: "Smartest-Garage-Fallback"
ap_password: ""

# Choose a strong password for OTA updates
ota_password: "change-me"

# Populated after CC1101 learn step.
# Format: binary string logged by remote_receiver, e.g. '010101010101010101010101'
garage_rf_code: ""

# 433.92 MHz is standard for most remotes. Adjust only if yours differs.
garage_rf_frequency: "433920"   # kHz
